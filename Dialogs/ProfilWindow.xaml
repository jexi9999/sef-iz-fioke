<Window x:Class="SefIzFioke.Dialogs.ProfilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moj profil"
        Width="400" Height="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border Background="White" CornerRadius="14" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.2" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="130"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Header sa pozadinom -->
            <Border Grid.Row="0" Background="#4A7A8F" CornerRadius="14,14,0,0">
                <Grid>
                    <!-- Dugme zatvori -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,10,12,0" Width="28" Height="28"
                            Foreground="White" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnZatvori_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="14"
                                                    Width="28" Height="28">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Avatar krug -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            BorderBrush="White" BorderThickness="3"
                            ClipToBounds="True"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,-40">
                        <Grid>
                            <Ellipse Fill="#2C5F6E"/>
                            <TextBlock x:Name="TxtAvatarEmoji" Text="👤" FontSize="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgAvatar" Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Informacije -->
            <StackPanel Grid.Row="1" Margin="30,52,30,10" HorizontalAlignment="Center">
                <!-- Korisničko ime -->
                <TextBlock x:Name="TxtKorisnickoIme"
                           FontSize="20" FontWeight="Bold" Foreground="#222"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <!-- Badge admin -->
                <Border x:Name="BadgeAdmin" Background="#4A7A8F" CornerRadius="10"
                        Padding="10,3" HorizontalAlignment="Center"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock Text="🛡 Administrator" Foreground="White" FontSize="11"/>
                </Border>

                <Separator Margin="0,0,0,16"/>

                <!-- Ime i prezime -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="👤  " FontSize="14" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Ime i prezime" FontSize="11" Foreground="#888"/>
                        <TextBlock x:Name="TxtImePrezime" FontSize="14" Foreground="#333"/>
                    </StackPanel>
                </StackPanel>

                <!-- Email -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✉  " FontSize="14" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Email adresa" FontSize="11" Foreground="#888"/>
                        <TextBlock x:Name="TxtEmail" FontSize="13" Foreground="#333" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Dugmad u footer-u -->
            <Border Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Moji recepti -->
                    <Button Content="📋  Moji recepti"
                            Foreground="#4A7A8F" Background="Transparent"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Margin="0,0,20,0"
                            Click="BtnMojiRecepti_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="8" Padding="16,8">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#EAF4F8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Odjava -->
                    <Button Content="🚪  Odjavi se"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#CC4444" Background="Transparent"
                        BorderThickness="0" FontSize="13" Cursor="Hand"
                        Click="BtnOdjava_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="8" Padding="20,8">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFEEEE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>