<Window x:Class="SefIzFioke.Dialogs.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prijava"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <DropShadowEffect x:Key="Senka" BlurRadius="20" ShadowDepth="0"
                          Color="#44000000" Opacity="0.4"/>
    </Window.Resources>

    <Border Margin="15" CornerRadius="16" Background="White"
            Effect="{StaticResource Senka}">
        <StackPanel Margin="30,28">

            <TextBlock Text="Log In" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Korisnicko ime -->
            <TextBlock Text="Korisničko ime" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtKorisnickoIme"
                     Height="42" Padding="10,10" FontSize="13"
                     Background="White" Foreground="Gray"
                     BorderBrush="#BBBBBB" BorderThickness="1"
                     Tag="Unesite korisničko ime..."
                     Text="Unesite korisničko ime..."
                     GotFocus="TextBox_GotFocus"
                     LostFocus="TextBox_LostFocus"
                     Margin="0,0,0,14"/>

            <!-- Lozinka -->
            <TextBlock Text="Lozinka" FontSize="13" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,8">
                <PasswordBox x:Name="PbLozinka"
                             Height="42" Padding="10,10" FontSize="13"
                             Background="White" Foreground="Black"
                             BorderBrush="#BBBBBB" BorderThickness="1"/>
                <TextBox x:Name="TxtLozinkaVidljiva"
                         Height="42" Padding="10,10" FontSize="13"
                         Background="White" Foreground="Black"
                         BorderBrush="#BBBBBB" BorderThickness="1"
                         Visibility="Collapsed"/>
                <Button x:Name="BtnToggleLozinka"
                        Content="👁" FontSize="16"
                        Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Foreground="#888"
                        Click="BtnToggleLozinka_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="6"
                                                Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <TextBlock Text="Zaboravili ste lozinku?"
                       Foreground="#4A7A8F" FontSize="12"
                       Cursor="Hand" HorizontalAlignment="Left"
                       Margin="0,0,0,20"
                       MouseLeftButtonUp="TxtZaboravio_Click"/>

            <!-- Dugmad -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Odustani" Style="{StaticResource OutlineDugme}"
                        Width="110" Margin="0,0,10,0"
                        Click="BtnOdustani_Click"/>
                <Button Content="Loguj se" Style="{StaticResource PrimarnoDigme}"
                        Width="110"
                        Click="BtnLoguj_Click"/>
            </StackPanel>

            <!-- Link ka registraciji -->
            <TextBlock Margin="0,14,0,4" HorizontalAlignment="Center"
                       FontSize="12" Cursor="Hand"
                       MouseLeftButtonUp="TxtRegistracija_Click">
                <Run Text="Nemate nalog? "/>
                <Run Text="Registrujte se" Foreground="#4A7A8F"
                     TextDecorations="Underline"/>
            </TextBlock>

            <!-- Poruka o gresci -->
            <TextBlock x:Name="TxtGreska" Foreground="Red"
                       FontSize="12" Margin="0,8,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>