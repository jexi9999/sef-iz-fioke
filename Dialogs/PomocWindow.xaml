<Window x:Class="SefIzFioke.Dialogs.PomocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomoć"
        Width="680" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border Background="White" CornerRadius="12" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.25" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Leva sidebar -->
            <Border Grid.Column="0" Background="#4A7A8F" CornerRadius="12,0,0,12">
                <StackPanel Margin="0,20,0,0">
                    <!-- Logo i naslov -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                        <Border Width="60" Height="60" Background="White" CornerRadius="30"
                                HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Image Source="/Assets/favicon_io/favicon.ico" Stretch="Uniform" Margin="6"/>
                        </Border>
                        <TextBlock Text="Šef iz fioke" Foreground="White" FontSize="15"
                                   FontFamily="Palatino Linotype" FontStyle="Italic"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Centar za pomoć" Foreground="#CCDDEE" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Kategorije -->
                    <ListBox x:Name="LstKategorije"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="LstKategorije_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="20,12"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3D6678"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2C4F5F"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem Tag="pocetna">🏠  Početna strana</ListBoxItem>
                        <ListBoxItem Tag="pretraga">🔍  Pretraga recepata</ListBoxItem>
                        <ListBoxItem Tag="recept">📋  Dodavanje recepta</ListBoxItem>
                        <ListBoxItem Tag="nalog">👤  Nalog i profil</ListBoxItem>
                        <ListBoxItem Tag="admin">🛡  Admin panel</ListBoxItem>
                        <ListBoxItem Tag="ostalo">ℹ️  O aplikaciji</ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Desni sadržaj -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header desne strane -->
                <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="25,0">
                    <Grid>
                        <TextBlock x:Name="TxtNaslovKategorije"
                                   Text="Izaberite temu"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#333333"
                                   VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="32" Height="32" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#888888" Cursor="Hand"
                                Click="BtnZatvori_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="16" Width="32" Height="32">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Sadržaj -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,20,25,20">
                    <StackPanel x:Name="PanelSadrzaj">

                        <!-- Početna strana -->
                        <StackPanel x:Name="PocetnaHelp" Visibility="Collapsed">
                            <TextBlock Text="Kako koristiti početnu stranu" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                       Text="Početna strana prikazuje karusel sa receptima poređanim po popularnosti — recepti sa najviše recenzija se prikazuju prvi."/>
                            <TextBlock Text="&#10;🔄  Navigacija kroz recepte" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Koristite dugmad &lt; i &gt; sa strane da prelistajte recepte, ili kliknite na tačkice na dnu karusela da skočite na određeni recept."/>
                            <TextBlock Text="&#10;👁  Detalji recepta" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na karticu recepta da vidite kompletan recept — sastojke, pripremu i recenzije."/>
                            <TextBlock Text="&#10;🔍  Pretraga" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na ikonicu lupe u gornjem desnom uglu da pređete na stranicu za pretragu."/>
                        </StackPanel>

                        <!-- Pretraga -->
                        <StackPanel x:Name="PretragaHelp" Visibility="Collapsed">
                            <TextBlock Text="Pretraga recepata" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                       Text="Stranica za pretragu vam omogućava da pronađete recept po više kriterijuma istovremeno."/>
                            <TextBlock Text="&#10;📝  Naziv recepta" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Unesite deo naziva recepta koji tražite. Polje nije osetljivo na velika/mala slova."/>
                            <TextBlock Text="&#10;🥗  Tip ishrane i alergije" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Izaberite tip ishrane (veganska, vegetarijanska...) i označite alergene koje treba isključiti."/>
                            <TextBlock Text="&#10;⏱  Vreme pripreme i porcije" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Filtrirajte recepte po maksimalnom vremenu pripreme i broju porcija koji vam odgovara."/>
                            <TextBlock Text="&#10;🔄  Resetovanje filtera" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na dugme 'Poništi filtere' da biste resetovali sve kriterijume pretrage."/>
                        </StackPanel>

                        <!-- Dodavanje recepta -->
                        <StackPanel x:Name="ReceptHelp" Visibility="Collapsed">
                            <TextBlock Text="Dodavanje novog recepta" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                       Text="Da biste dodali recept, morate biti prijavljeni. Kliknite na ikonicu 📋 u hederu."/>
                            <TextBlock Text="&#10;✏️  Osnovne informacije" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Popunite naziv recepta, unesite sastojke (svaki u novom redu) i opišite korake pripreme."/>
                            <TextBlock Text="&#10;🖼  Fotografija recepta" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na dugme 'Odaberi sliku' da dodate fotografiju jela sa svog računara (JPG, PNG)."/>
                            <TextBlock Text="&#10;⚙️  Kategorije i detalji" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Podesite kategoriju jela, vreme pripreme i broj porcija pre nego što sačuvate recept."/>
                        </StackPanel>

                        <!-- Nalog -->
                        <StackPanel x:Name="NalogHelp" Visibility="Collapsed">
                            <TextBlock Text="Nalog i profil" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock Text="📝  Registracija" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,12"
                                       Text="Kliknite na ikonicu 👤 u hederu, pa na 'Nemate nalog? Registrujte se'. Unesite korisničko ime, email i lozinku (min. 6 karaktera). Možete dodati i profilnu fotografiju."/>
                            <TextBlock Text="🔑  Prijava" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,12"
                                       Text="Kliknite na ikonicu 👤 i unesite vaše korisničko ime i lozinku."/>
                            <TextBlock Text="🚪  Odjava" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na ikonicu 🚪 u hederu da se odjavite."/>
                        </StackPanel>

                        <!-- Admin -->
                        <StackPanel x:Name="AdminHelp" Visibility="Collapsed">
                            <TextBlock Text="Admin panel" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                       Text="Admin panel je dostupan samo administratorima aplikacije. Ikonica 🛡 se pojavljuje u hederu nakon prijave admin naloga."/>
                            <TextBlock Text="&#10;👥  Pregled korisnika" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Vidite listu svih registrovanih korisnika sa korisničkim imenom i email adresom."/>
                            <TextBlock Text="&#10;⚠️  Upozorenje" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na '⚠ Upozori' pored korisnika da mu pošaljete upozorenje zbog neprimerenog ponašanja."/>
                            <TextBlock Text="&#10;🚫  Blokiranje korisnika" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Kliknite na '🚫 Izbaci' da uklonite korisnika iz aplikacije. Ova akcija je trajna."/>
                        </StackPanel>

                        <!-- O aplikaciji -->
                        <StackPanel x:Name="OstaloHelp" Visibility="Collapsed">
                            <TextBlock Text="O aplikaciji" FontSize="15" FontWeight="Bold"
                                       Foreground="#4A7A8F" Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#444" FontSize="13" LineHeight="22"
                                       Text="Šef iz fioke je aplikacija za deljenje i pretragu recepata."/>
                            <TextBlock Text="&#10;🛠  Tehnologije" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="Aplikacija je razvijena u WPF (.NET 8) sa SQLite bazom podataka."/>
                            <TextBlock Text="&#10;💡  Saveti" FontWeight="SemiBold" Foreground="#333" FontSize="13"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="13" LineHeight="22" Margin="0,4,0,0"
                                       Text="• Za dodavanje recepta obavezno se prijavite prvo.&#10;• Recepti se sortiraju po broju recenzija.&#10;• Koristite filtere pretrage za preciznije rezultate."/>
                        </StackPanel>

                        <!-- Početna poruka -->
                        <StackPanel x:Name="PocetnaPorukaPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="0,60,0,0">
                            <TextBlock Text="👋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Dobrodošli u centar za pomoć!" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#333" HorizontalAlignment="Center"/>
                            <TextBlock Text="Izaberite temu sa leve strane." FontSize="13" Foreground="#888"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>