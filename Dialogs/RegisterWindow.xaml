<Window x:Class="SefIzFioke.Dialogs.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrovanje"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <DropShadowEffect x:Key="Senka" BlurRadius="20" ShadowDepth="0"
                          Color="#44000000" Opacity="0.4"/>
    </Window.Resources>

    <Border Margin="15" CornerRadius="16" Background="White"
            Effect="{StaticResource Senka}">
        <StackPanel Margin="30,24">

            <TextBlock Text="Registrovanje" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,18"/>

            <!-- Profilna fotografija -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,18">
                <Border Width="90" Height="90" CornerRadius="45"
                        BorderBrush="#BBBBBB" BorderThickness="2"
                        ClipToBounds="True" HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                    <Grid>
                        <Ellipse Fill="#EBF4F8"/>
                        <TextBlock x:Name="TxtAvatarEmoji" Text="👤"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Image x:Name="ImgProfilna" Stretch="UniformToFill"
                               Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <Button Content="📷 Dodaj fotografiju"
                        HorizontalAlignment="Center"
                        Padding="12,5" FontSize="12"
                        Background="Transparent"
                        Foreground="#4A7A8F"
                        BorderBrush="#4A7A8F"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnDodajFoto_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EBF4F8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Korisnicko ime -->
            <TextBlock Text="Korisničko ime" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtKorisnickoIme"
                     Height="42" Padding="10,10" FontSize="13"
                     Background="White" Foreground="Gray"
                     BorderBrush="#BBBBBB" BorderThickness="1"
                     Tag="Izaberite korisničko ime..."
                     Text="Izaberite korisničko ime..."
                     GotFocus="TextBox_GotFocus"
                     LostFocus="TextBox_LostFocus"
                     Margin="0,0,0,10"/>

            <!-- Ime i Prezime u jednom redu -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ime" FontSize="13" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtIme"
                             Height="42" Padding="10,10" FontSize="13"
                             Background="White" Foreground="Gray"
                             BorderBrush="#BBBBBB" BorderThickness="1"
                             Tag="Ime..."
                             Text="Ime..."
                             GotFocus="TextBox_GotFocus"
                             LostFocus="TextBox_LostFocus"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Prezime" FontSize="13" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPrezime"
                             Height="42" Padding="10,10" FontSize="13"
                             Background="White" Foreground="Gray"
                             BorderBrush="#BBBBBB" BorderThickness="1"
                             Tag="Prezime..."
                             Text="Prezime..."
                             GotFocus="TextBox_GotFocus"
                             LostFocus="TextBox_LostFocus"/>
                </StackPanel>
            </Grid>

            <!-- Email -->
            <TextBlock Text="Email" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtEmail"
                     Height="42" Padding="10,10" FontSize="13"
                     Background="White" Foreground="Gray"
                     BorderBrush="#BBBBBB" BorderThickness="1"
                     Tag="primer@gmail.com"
                     Text="primer@gmail.com"
                     GotFocus="TextBox_GotFocus"
                     LostFocus="TextBox_LostFocus"
                     Margin="0,0,0,10"/>

            <!-- Lozinka -->
            <TextBlock Text="Lozinka" FontSize="13" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,18">
                <PasswordBox x:Name="PbLozinka"
                             Height="42" Padding="10,10" FontSize="13"
                             Background="White" Foreground="Black"
                             BorderBrush="#BBBBBB" BorderThickness="1"/>
                <TextBox x:Name="TxtLozinkaVidljiva"
                         Height="42" Padding="10,10" FontSize="13"
                         Background="White" Foreground="Black"
                         BorderBrush="#BBBBBB" BorderThickness="1"
                         Visibility="Collapsed"/>
                <Button x:Name="BtnToggleLozinka"
                        Content="👁" FontSize="16"
                        Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Foreground="#888"
                        Click="BtnToggleLozinka_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="6" Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Dugmad -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Odustani" Style="{StaticResource OutlineDugme}"
                        Width="110" Margin="0,0,10,0"
                        Click="BtnOdustani_Click"/>
                <Button Content="Registruj se" Style="{StaticResource PrimarnoDigme}"
                        Width="120" Click="BtnRegistruj_Click"/>
            </StackPanel>

            <!-- Link ka logovanju -->
            <TextBlock Margin="0,12,0,4" HorizontalAlignment="Center"
                       FontSize="12" Cursor="Hand"
                       MouseLeftButtonUp="TxtLogin_Click">
                <Run Text="Već imate nalog? "/>
                <Run Text="Prijavite se" Foreground="#4A7A8F"
                     TextDecorations="Underline"/>
            </TextBlock>

            <!-- Poruka o gresci -->
            <TextBlock x:Name="TxtGreska" Foreground="Red"
                       FontSize="12" Margin="0,6,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>