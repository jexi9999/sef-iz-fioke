<Page x:Class="SefIzFioke.Views.UnosReceptaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#5B8FA8"
      Title="Unos recepta">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#4A7A8F" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="White" CornerRadius="6" Margin="0,0,10,0">
                        <Image Source="/Assets/favicon_io/favicon.ico" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock FontSize="18" Foreground="White" VerticalAlignment="Center"
                               FontFamily="Palatino Linotype" FontStyle="Italic">
                        <Run Text="Šef iz fioke"/>
                        <Run Text=" > unos recepata" Foreground="#CCCCCC" FontSize="13"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Content="← Nazad"
                        Style="{StaticResource HeaderDugme}"
                        Width="Auto" Padding="12,0" FontSize="14"
                        Click="BtnNazad_Click" Margin="15,0,0,0"/>
                <Button Grid.Column="3" Content="Povratak na meni"
                        Style="{StaticResource OutlineDugme}"
                        Foreground="White" BorderBrush="White"
                        Click="BtnPovratak_Click" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderDugme}" Content="❓" ToolTip="Pomoć" Click="BtnPomoc_Click"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="⚙"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="🚪"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="👤"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SADRZAJ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <!-- LEVA KOLONA -->
                <StackPanel Grid.Column="0">

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Naziv recepta" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtNaziv"
                                     Margin="0,6,0,0" Height="38" Padding="8,8"
                                     FontSize="13" Background="White"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Unesite naziv recepta..."
                                     Text="Unesite naziv recepta..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Namirnice" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtNamirnice"
                                     Margin="0,6,0,0" Height="65" Padding="8,8"
                                     FontSize="13" Background="White" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Npr. jaja, mleko, brašno..."
                                     Text="Npr. jaja, mleko, brašno..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Vreme pripreme" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtVremePripreme"
                                     Margin="0,6,0,0" Height="38" Padding="8,8"
                                     FontSize="13" Background="White"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Npr. 30 minuta, 1 sat..."
                                     Text="Npr. 30 minuta, 1 sat..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Sastojci" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtSastojci"
                                     Margin="0,6,0,0" Height="90" Padding="8,8"
                                     FontSize="13" Background="White" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Npr. 100g brašna, 2 jaja..."
                                     Text="Npr. 100g brašna, 2 jaja..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Način pripreme" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtNacinPripreme"
                                     Margin="0,6,0,0" Height="100" Padding="8,8"
                                     FontSize="13" Background="White" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="1. Korak prvi...&#10;2. Korak drugi..."
                                     Text="1. Korak prvi...&#10;2. Korak drugi..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Video" FontWeight="SemiBold" FontSize="13"/>
                            <Button Content="📹 Dodaj video" Style="{StaticResource OutlineDugme}"
                                    Margin="0,8,0,0" Click="BtnDodajVideo_Click"/>
                            <TextBlock x:Name="TxtVideoPath" FontSize="11" Foreground="Gray"
                                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DESNA KOLONA -->
                <StackPanel Grid.Column="2">

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Kratak opis" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtKratakOpis"
                                     Margin="0,6,0,0" Height="75" Padding="8,8"
                                     FontSize="13" Background="White" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Kratko opišite recept..."
                                     Text="Kratko opišite recept..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Dijetetske restrikcije" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtRestrikcije"
                                     Margin="0,6,0,0" Height="38" Padding="8,8"
                                     FontSize="13" Background="White"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Npr. vegetarijansko, bez glutena..."
                                     Text="Npr. vegetarijansko, bez glutena..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Napomene" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtNapomene"
                                     Margin="0,6,0,0" Height="75" Padding="8,8"
                                     FontSize="13" Background="White" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Dodatne napomene, alergeni..."
                                     Text="Dodatne napomene, alergeni..."
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Slike" FontWeight="SemiBold" FontSize="13"/>
                            <Button Content="🖼 Dodaj slike" Style="{StaticResource OutlineDugme}"
                                    Margin="0,8,0,6" Click="BtnDodajSlike_Click"/>
                            <WrapPanel x:Name="PanelSlike"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Broj porcija" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox x:Name="TxtBrojPorcija"
                                     Margin="0,6,0,0" Height="38" Padding="8,8"
                                     FontSize="13" Background="White"
                                     Foreground="Gray" BorderBrush="#BBBBBB" BorderThickness="1"
                                     Tag="Npr. 4"
                                     Text="Npr. 4"
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- DEKORATIVNE SLIKE -->
                <Border Grid.Column="4" CornerRadius="15" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#7BA5B8" CornerRadius="10" Margin="3">
                            <TextBlock Text="🥞" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Background="#7BA5B8" CornerRadius="10" Margin="3">
                            <TextBlock Text="🫐" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="2" Background="#7BA5B8" CornerRadius="10" Margin="3">
                            <TextBlock Text="🍕" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- DUGMAD -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Odustani" Style="{StaticResource OutlineDugme}"
                    Width="120" Click="BtnOdustani_Click" Margin="0,0,15,0"/>
            <Button x:Name="BtnPostavi" Content="Postavi" Style="{StaticResource PrimarnoDigme}"
                    Width="120" Click="BtnPostavi_Click"/>
        </StackPanel>
    </Grid>
</Page>