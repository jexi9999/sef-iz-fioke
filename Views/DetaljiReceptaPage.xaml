<Page x:Class="SefIzFioke.Views.DetaljiReceptaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#5B8FA8"
      Title="Detalji recepta">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#4A7A8F" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="White" CornerRadius="6" Margin="0,0,10,0">
                        <Image Source="/Assets/favicon_io/favicon.ico" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock FontSize="18" Foreground="White" VerticalAlignment="Center"
                               FontFamily="Palatino Linotype" FontStyle="Italic">
                        <Run Text="Šef iz fioke"/>
                        <Run Text=" > detalji recepta" Foreground="#CCCCCC" FontSize="13"/>
                    </TextBlock>
                </StackPanel>

                <!-- Dugme Nazad -->
                <Button Grid.Column="1"
                        Content="← Nazad"
                        Style="{StaticResource HeaderDugme}"
                        Width="Auto" Padding="12,0"
                        FontSize="14"
                        Click="BtnNazad_Click"
                        Margin="15,0,0,0"/>

                <!-- Uredi recept (vidljivo samo autoru/adminu) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button x:Name="BtnUredi"
                            Content="✏ Uredi recept"
                            Style="{StaticResource OutlineDugme}"
                            Foreground="White" BorderBrush="White"
                            Visibility="Collapsed"
                            Click="BtnUredi_Click" Margin="0,0,10,0"/>
                    <Button Content="Povratak na meni"
                            Style="{StaticResource OutlineDugme}"
                            Foreground="White" BorderBrush="White"
                            Click="BtnPovratak_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderDugme}" Content="❓" ToolTip="Pomoć" Click="BtnPomoc_Click"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="⚙"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="🚪" Click="BtnLogout_Click"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="👤" Click="BtnLogin_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SADRZAJ -->
        <Grid Grid.Row="1" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEVA KOLONA -->
            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <!-- Slika -->
                <Border CornerRadius="12" ClipToBounds="True"
                        Height="180" Background="#7BA5B8" Margin="0,0,0,10">
                    <Grid>
                        <Image x:Name="ImgRecept" Stretch="UniformToFill"/>
                        <TextBlock x:Name="TxtNemaSliku" Text="🍽" FontSize="70"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Visible"/>
                        <Button Content="🖼 Galerija"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                Margin="8" Padding="6,3"
                                Background="#88000000" Foreground="White"
                                BorderThickness="0" FontSize="11"
                                Click="BtnGalerija_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Komentari -->
                <Border Background="White" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="TxtBrojKomentara"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ListaKomentara">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        ClipToBounds="True" Margin="0,0,6,0">
                                                    <Grid>
                                                        <Ellipse Fill="#5B8FA8"/>
                                                        <Image Stretch="UniformToFill"
                                                               Loaded="ImgAvatar_Loaded"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Komentar.Korisnik.KorisnickoIme}"
                                                               FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock x:Name="TxtZvezde"
                                                               FontSize="11"
                                                               Text="{Binding Komentar.Ocena, Mode=OneWay, Converter={StaticResource OcenaConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Komentar.Tekst}"
                                                       FontSize="11" Foreground="#555"
                                                       TextWrapping="Wrap" Margin="34,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- DESNA KOLONA -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtNaziv" FontSize="26" FontWeight="Bold"
                               Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtAutor" FontSize="13" Foreground="#DDDDDD"
                               Margin="0,4,0,4"/>
                    <!-- Vreme i porcije u jednom redu -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#3D6678" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock x:Name="TxtVremeTag" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border Background="#3D6678" CornerRadius="6" Padding="8,4">
                            <TextBlock x:Name="TxtPorcijeTag" Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="Kratak opis:" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TxtKratakOpis" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,2,0,12"/>

                    <TextBlock Text="Dijetetske restrikcije:" Foreground="White"
                               FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TxtRestrikcije" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,2,0,12"/>

                    <TextBlock Text="Sastojci:" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TxtSastojci" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,2,0,12"/>

                    <TextBlock Text="Napomene:" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TxtNapomene" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,2,0,12"/>

                    <TextBlock Text="Način pripreme:" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TxtNacinPripreme" Foreground="White" FontSize="13"
                               TextWrapping="Wrap" Margin="0,2,0,20"/>

                    <!-- Forma za komentar -->
                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,10"
                            x:Name="FormaKomentar">
                        <StackPanel>
                            <TextBlock Text="Ostavite recenziju" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,0,0,8"/>

                            <!-- Zvezdice za ocenu -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Ocena: " FontSize="12" Foreground="#555"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button x:Name="Star1" Content="☆" FontSize="22" Foreground="#F5A623"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Tag="1" Click="Star_Click" Padding="2"/>
                                <Button x:Name="Star2" Content="☆" FontSize="22" Foreground="#F5A623"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Tag="2" Click="Star_Click" Padding="2"/>
                                <Button x:Name="Star3" Content="☆" FontSize="22" Foreground="#F5A623"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Tag="3" Click="Star_Click" Padding="2"/>
                                <Button x:Name="Star4" Content="☆" FontSize="22" Foreground="#F5A623"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Tag="4" Click="Star_Click" Padding="2"/>
                                <Button x:Name="Star5" Content="☆" FontSize="22" Foreground="#F5A623"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Tag="5" Click="Star_Click" Padding="2"/>
                                <TextBlock x:Name="TxtOcenaLabel" Text="(nije ocenjeno)"
                                           FontSize="11" Foreground="#888"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBox x:Name="TxtKomentar"
                                     Style="{StaticResource UnosPolje}"
                                     Height="60" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Foreground="Black" Background="White"
                                     Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Poništi" Style="{StaticResource OutlineDugme}"
                                        Padding="14,7" Margin="0,0,10,0"
                                        Click="BtnPonistiKomentar_Click"/>
                                <Button Content="Postavi" Style="{StaticResource PrimarnoDigme}"
                                        Padding="14,7" Click="BtnPostavi_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>