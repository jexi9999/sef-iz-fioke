<Page x:Class="SefIzFioke.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#5B8FA8"
      Title="Admin panel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#3D5A6B" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="White" CornerRadius="6" Margin="0,0,10,0">
                        <Image Source="/Assets/favicon_io/favicon.ico" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock FontSize="18" Foreground="White" VerticalAlignment="Center"
                               FontFamily="Palatino Linotype" FontStyle="Italic">
                        <Run Text="Šef iz fioke"/>
                        <Run Text=" > admin panel" Foreground="#CCCCCC" FontSize="13"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1" Content="← Nazad"
                        Style="{StaticResource HeaderDugme}"
                        Width="Auto" Padding="12,0" FontSize="14"
                        Click="BtnNazad_Click" Margin="15,0,0,0"/>

                <Button Grid.Column="3" Content="Povratak na meni"
                        Style="{StaticResource OutlineDugme}"
                        Foreground="White" BorderBrush="White"
                        Click="BtnPovratak_Click" Margin="0,0,15,0"/>
            </Grid>
        </Border>

        <!-- SADRZAJ -->
        <Grid Grid.Row="1" Margin="20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TAB DUGMAD -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <!-- Tab: Korisnici -->
                <Border x:Name="BtnTabKorisnici" Background="White" CornerRadius="8"
                        Margin="0,0,8,0" Cursor="Hand"
                        MouseLeftButtonUp="BtnTabKorisnici_Click">
                    <StackPanel Orientation="Horizontal" Margin="16,8">
                        <TextBlock Text="👥 Korisnici" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2E5266" VerticalAlignment="Center"/>
                        <Border Background="#4A7A8F" CornerRadius="8" Padding="7,2" Margin="8,0,0,0">
                            <TextBlock x:Name="TxtBrojKorisnika" Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>
                <!-- Tab: Recepti -->
                <Border x:Name="BtnTabRecepti" Background="#3D6B7F" CornerRadius="8"
                        Cursor="Hand" MouseLeftButtonUp="BtnTabRecepti_Click">
                    <StackPanel Orientation="Horizontal" Margin="16,8">
                        <TextBlock Text="📋 Recepti" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <Border Background="#5B8FA8" CornerRadius="8" Padding="7,2" Margin="8,0,0,0">
                            <TextBlock x:Name="TxtBrojRecepata" Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- PANEL KORISNICI -->
            <ScrollViewer x:Name="PanelKorisnici" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ListaKorisnika">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12"
                                    Margin="0,0,0,12" Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Grid.Column="0" Width="40" Height="40"
                                            CornerRadius="20" Background="#5B8FA8">
                                        <TextBlock Text="👤" FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding KorisnickoIme}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="#222"/>
                                            <Border x:Name="AdminBadge"
                                                    Background="#E8F4FD" CornerRadius="4"
                                                    Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="ADMIN" FontSize="10"
                                                           Foreground="#2E6B84" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#FFF3CD" CornerRadius="4"
                                                    Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding JeBlokirn, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="BLOKIRAN" FontSize="10"
                                                           Foreground="#856404" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="12" Foreground="#666"/>
                                        <TextBlock FontSize="11" Foreground="#999">
                                            <Run Text="Recepti: "/>
                                            <Run Text="{Binding Recepti.Count, Mode=OneWay}"/>
                                            <Run Text="   Komentari: "/>
                                            <Run Text="{Binding Komentari.Count, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Dugme: Upozori -->
                                    <Button Grid.Column="2"
                                            Content="⚠ Upozori"
                                            Margin="0,0,10,0"
                                            Padding="12,7"
                                            Background="#FFC107"
                                            Foreground="#333"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="BtnUpozori_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="7"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E0A800"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Dugme: Izbaci -->
                                    <Button Grid.Column="3"
                                            Content="🚫 Izbaci"
                                            Padding="12,7"
                                            Background="#DC3545"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            Click="BtnIzbaci_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="7"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#B02A37"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- PANEL RECEPTI -->
            <ScrollViewer x:Name="PanelRecepti" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <ItemsControl x:Name="ListaRecepataAdmin">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12"
                                    Margin="0,0,0,10" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Slika -->
                                    <Border Grid.Column="0" Width="64" Height="64"
                                            CornerRadius="8" ClipToBounds="True"
                                            Background="#EAF4F8">
                                        <Grid>
                                            <TextBlock Text="🍽" FontSize="28"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#AAA"/>
                                            <Image Stretch="UniformToFill"
                                                   Loaded="ImgAdminRecept_Loaded"/>
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="14,0,10,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Naziv}"
                                                   FontSize="14" FontWeight="Bold" Foreground="#222"/>
                                        <TextBlock FontSize="12" Foreground="#888" Margin="0,2,0,0">
                                            <Run Text="Autor: "/>
                                            <Run Text="{Binding Korisnik.KorisnickoIme, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="#AAA" Margin="0,2,0,0">
                                            <Run Text="{Binding VremePripreme, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding BrojPorcija, Mode=OneWay}"/>
                                            <Run Text=" porcija"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Uredi -->
                                    <Button Grid.Column="2"
                                            Content="✏ Uredi"
                                            Margin="0,0,8,0" Padding="10,7"
                                            Background="#4A7A8F" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding}" Click="BtnUrediAdmin_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#3D6B7F"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Obriši -->
                                    <Button Grid.Column="3"
                                            Content="🗑 Obriši"
                                            Padding="10,7"
                                            Background="#DC3545" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Tag="{Binding}" Click="BtnObrisiRecept_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#B02A37"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>