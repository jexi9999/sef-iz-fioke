<Page x:Class="SefIzFioke.Views.RezultatiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#5B8FA8"
      Title="Rezultati pretrage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#4A7A8F" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="White" CornerRadius="6" Margin="0,0,10,0">
                        <Image Source="/Assets/favicon_io/favicon.ico" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock FontSize="18" Foreground="White" VerticalAlignment="Center"
                               FontFamily="Palatino Linotype" FontStyle="Italic">
                        <Run Text="Šef iz fioke"/>
                        <Run Text=" > rezultati pretrage" Foreground="#CCCCCC" FontSize="13"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1" Content="← Nazad"
                        Style="{StaticResource HeaderDugme}"
                        Width="Auto" Padding="12,0" FontSize="14"
                        Click="BtnNazad_Click" Margin="15,0,0,0"/>

                <Button Grid.Column="3" Content="Povratak na meni"
                        Style="{StaticResource OutlineDugme}"
                        Foreground="White" BorderBrush="White"
                        Click="BtnPovratak_Click" Margin="0,0,15,0"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderDugme}" Content="❓" ToolTip="Pomoć" Click="BtnPomoc_Click"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="⚙"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="🚪" Click="BtnLogout_Click"/>
                    <Button Style="{StaticResource HeaderDugme}" Content="👤" Click="BtnLogin_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA REZULTATA -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,15">
            <StackPanel>
                <TextBlock x:Name="TxtBrojRezultata"
                           Foreground="White" FontSize="14" Margin="0,0,0,12"/>
                <ItemsControl x:Name="ListaRecepata">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="16" Margin="0,0,0,18"
                                    ClipToBounds="True">
                                <Grid Height="200">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Slika -->
                                    <Border Grid.Column="0" CornerRadius="14,0,0,14"
                                            ClipToBounds="True" Background="#C0D8E4">
                                        <Grid>
                                            <TextBlock x:Name="TxtPlaceholder" Text="🍽" FontSize="75"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Image Stretch="UniformToFill"
                                                   Tag="{Binding SlikaPath}"
                                                   Loaded="ImgKartica_Loaded"/>
                                        </Grid>
                                    </Border>

                                    <!-- Tekst -->
                                    <StackPanel Grid.Column="1" Margin="22,18,18,18"
                                                VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Naziv}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="#222" FontFamily="Courier New"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <TextBlock FontSize="12" Foreground="#666">
                                                <Run Text="Autor: "/>
                                                <Run Text="{Binding Korisnik.KorisnickoIme}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#888" Margin="12,0,0,0">
                                                <Run Text="⭐ "/>
                                                <Run Text="{Binding Komentari.Count, Mode=OneWay}"/>
                                                <Run Text=" recenzija"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding KratakOpis}"
                                                   FontSize="12" Foreground="#444"
                                                   TextWrapping="Wrap" MaxHeight="70"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#EBF4F8" CornerRadius="5"
                                                    Padding="7,3" Margin="0,0,8,0">
                                                <TextBlock FontSize="11" Foreground="#4A7A8F">
                                                    <Run Text="⏱ "/>
                                                    <Run Text="{Binding VremePripreme}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#EBF4F8" CornerRadius="5" Padding="7,3">
                                                <TextBlock FontSize="11" Foreground="#4A7A8F">
                                                    <Run Text="🍽 "/>
                                                    <Run Text="{Binding BrojPorcija}"/>
                                                    <Run Text=" porcija"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <Button Content="Pogledaj recept"
                                                Style="{StaticResource OutlineDugme}"
                                                HorizontalAlignment="Left"
                                                Margin="0,10,0,0" Padding="12,5"
                                                Tag="{Binding}"
                                                Click="BtnPogledaj_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>